{
  "expo": {
    "name": "AD Lanzarote",
    "slug": "my-app",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1D7D8A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "es.adlanzarote.app",
      "buildNumber": "1"
    },
    "android": {
      "package": "es.adlanzarote.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1D7D8A"
      },
      "edgeToEdgeEnabled": false,
      "permissions": ["INTERNET"]
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "d55475df-fadc-47bc-ab04-645de7ddd35e"
      }
    }
  }
}
